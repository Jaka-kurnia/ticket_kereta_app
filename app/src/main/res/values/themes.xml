<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Ticket_wosh_app" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/bgLight</item>
    </style>

    <style name="Theme.Ticket_wosh_app" parent="Base.Theme.Ticket_wosh_app" />

    <!-- Style for Bottom Navigation Text Labels -->
    <style name="BottomNavTextActive" parent="Widget.Design.BottomNavigationView">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavTextInactive" parent="Widget.Design.BottomNavigationView">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-normal</item>
    </style>
</resources>