<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgLight"
    tools:context=".ui.PaymentActivity">

    <!-- Header / Toolbar -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/white"
            android:contentDescription="Home" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Transaksi &amp; Tiket"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- STATE PENDING: Menunggu Pembayaran -->
            <LinearLayout
                android:id="@+id/layoutPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selesaikan Pembayaran Anda"
                    android:textColor="@color/textDark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Countdown Timer -->
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="15:00"
                    android:textColor="@color/colorPrimary"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sisa waktu pembayaran tiket Anda"
                    android:textColor="@color/textLight"
                    android:textSize="12sp" />

                <!-- Detail Bayar Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="@color/cardBg"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/surfaceGrey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kode Bayar Virtual Account"
                            android:textColor="@color/textLight"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvPaymentCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="WSH72839485"
                            android:textColor="@color/textDark"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textIsSelectable="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Total Nominal"
                            android:textColor="@color/textLight"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvPendingPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rp 250.000"
                            android:textColor="@color/colorPrimary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tombol Simulasi Pembayaran -->
                <Button
                    android:id="@+id/btnSimulatePayment"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Selesaikan Pembayaran"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="8dp" />

                <ProgressBar
                    android:id="@+id/progressPayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:indeterminateTint="@color/colorPrimary" />

            </LinearLayout>

            <!-- STATE PAID: Tiket Digital -->
            <LinearLayout
                android:id="@+id/layoutPaid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <!-- Success Header -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="@color/seatAvailable"
                    android:contentDescription="Success" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Pembayaran Berhasil!"
                    android:textColor="@color/seatAvailable"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tiket elektronik Anda telah diterbitkan"
                    android:textColor="@color/textLight"
                    android:textSize="13sp" />

                <!-- E-Ticket Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/cardBg"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/surfaceGrey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Red Header of Ticket -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/colorPrimary"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="BOARDING PASS"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvTicketCode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WSHXXXX"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Ticket Body -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="center_horizontal">

                            <!-- Train Name & Route -->
                            <TextView
                                android:id="@+id/tvTicketTrainName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Whoosh G1203"
                                android:textColor="@color/textDark"
                                android:textStyle="bold"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvTicketRoute"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Halim ➔ Tegalluar"
                                android:textColor="@color/textDark"
                                android:textSize="15sp"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tvTicketDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15 Juni 2026 | 08:00 WIB"
                                android:textColor="@color/textLight"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/surfaceGrey"
                                android:layout_marginVertical="16dp" />

                            <!-- Passenger & Seat Detail -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:id="@+id/tvTicketPassenger"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nama: Kurnia"
                                    android:textColor="@color/textDark"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/tvTicketSeat"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:text="Kursi: A1"
                                    android:textColor="@color/colorPrimary"
                                    android:textStyle="bold"
                                    android:textSize="14sp" />
                            </RelativeLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/surfaceGrey"
                                android:layout_marginVertical="16dp" />

                            <!-- QR Code Visual Representation -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan QR ini pada Gate Stasiun"
                                android:textColor="@color/textLight"
                                android:textSize="11sp"
                                android:layout_marginBottom="8dp" />

                            <!-- Simulating QR image using placeholder -->
                            <ImageView
                                android:id="@+id/imgQrCode"
                                android:layout_width="160dp"
                                android:layout_height="160dp"
                                android:src="@android:drawable/ic_dialog_map"
                                app:tint="@color/black"
                                android:contentDescription="Tiket QR Code" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btnBackToHome"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Kembali Ke Menu Utama"
                    android:textColor="@color/colorPrimary"
                    app:strokeColor="@color/colorPrimary"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
