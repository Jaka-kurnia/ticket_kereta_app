<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgLight"
    tools:context=".ui.HomeActivity">

    <!-- Top Red Gradient Background (like BRImo header) -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Bar Header -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUserGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Pagi,"
                android:textColor="@color/white"
                android:alpha="0.8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kurnia Woosh"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Notification & Logout Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnNotification"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@color/white"
                android:contentDescription="Notification" />

            <ImageButton
                android:id="@+id/btnHomeLogout"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="@color/white"
                android:contentDescription="Logout" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Scrollable Dashboard Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Wallet / Point Info Card (BRImo Account style card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWallet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/cardBg"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Whoosh Card &amp; Points"
                            android:textColor="@color/textLight"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Premium Class"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvWoshPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="12,450 Pts"
                        android:textColor="@color/textDark"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surfaceGrey"
                        android:layout_marginVertical="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Action Item 1 -->
                        <LinearLayout
                            android:id="@+id/btnTopUp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_input_add"
                                app:tint="@color/colorPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Top Up"
                                android:textSize="11sp"
                                android:textColor="@color/textDark"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Action Item 2 -->
                        <LinearLayout
                            android:id="@+id/btnPromo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/btn_star_big_on"
                                app:tint="@color/colorAccent" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Promo"
                                android:textSize="11sp"
                                android:textColor="@color/textDark"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Action Item 3 -->
                        <LinearLayout
                            android:id="@+id/btnQRScan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_dialog_map"
                                app:tint="@color/colorPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan Gate"
                                android:textSize="11sp"
                                android:textColor="@color/textDark"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Access Menu Grid (BRImo style 4x2) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Layanan Utama"
                android:textColor="@color/textDark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:layout_marginTop="12dp"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Menu 1: Pesan Tiket -->
                <LinearLayout
                    android:id="@+id/menuBookTicket"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_primary"
                        android:foreground="@android:drawable/ic_menu_my_calendar"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pesan Tiket"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Menu 2: Tiket Saya -->
                <LinearLayout
                    android:id="@+id/menuMyTicket"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_accent"
                        android:foreground="@android:drawable/ic_menu_gallery"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiket Saya"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Menu 3: Rute Map -->
                <LinearLayout
                    android:id="@+id/menuRoutes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_blue"
                        android:foreground="@android:drawable/ic_dialog_map"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rute Kereta"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Menu 4: Refund -->
                <LinearLayout
                    android:id="@+id/menuRefund"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_purple"
                        android:foreground="@android:drawable/ic_menu_revert"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Refund"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Row 2 -->
                <!-- Menu 5: Jadwal -->
                <LinearLayout
                    android:id="@+id/menuSchedules"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_orange"
                        android:foreground="@android:drawable/ic_menu_info_details"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jadwal"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Menu 6: Stasiun -->
                <LinearLayout
                    android:id="@+id/menuStations"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_teal"
                        android:foreground="@android:drawable/ic_menu_compass"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stasiun"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Menu 7: Food & Beverage -->
                <LinearLayout
                    android:id="@+id/menuFood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_green"
                        android:foreground="@android:drawable/ic_menu_view"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kuliner"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Menu 8: CS / Bantuan -->
                <LinearLayout
                    android:id="@+id/menuSupport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_bg_gray"
                        android:foreground="@android:drawable/ic_menu_call"
                        android:foregroundGravity="center"
                        android:foregroundTint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bantuan"
                        android:textSize="11sp"
                        android:textColor="@color/textDark"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </GridLayout>

            <!-- Promo & Discounts (BRImo banner card style) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Promo Menarik"
                android:textColor="@color/textDark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Mock Promo Banner Image -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@color/colorPrimaryDark" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cashback 20% Pakai QRIS BRImo"
                            android:textColor="@color/textDark"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dapatkan cashback langsung untuk setiap pemesanan tiket kereta cepat Whoosh menggunakan QRIS BRImo."
                            android:textColor="@color/textLight"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar (BRImo Style) -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/cardBg"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/home_bottom_menu"
        app:itemIconTint="@color/colorPrimary"
        app:itemTextColor="@color/textDark" />

</androidx.constraintlayout.widget.ConstraintLayout>
